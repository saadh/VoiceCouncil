# These are the values the Insforge edge functions read at runtime. Set them as
# Insforge function SECRETS (NOT local env) once your CLI is linked:
#   npx @insforge/cli secrets add <NAME> <value>
# Then deploy everything with: bash backend/deploy.sh

# Nebius Token Factory (LLM — panelist personas + deliberation)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1
# Optional model overrides:
NEBIUS_MODEL=              # vapi-llm fallback when the request omits a model
NEBIUS_PANEL_MODELS=       # csv: 3 panel models for prep-plan/verdict fan-out
NEBIUS_SYNTH_MODEL=        # synthesis model (defaults to first panel model)

# Vapi (voice)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=

# Insforge (backend / DB) — required by vapi-webhook, prep-plan, verdict
INSFORGE_API_KEY=
INSFORGE_PROJECT_URL=

# Optional:
VAPI_SERVER_SECRET=        # shared secret; must match vapi/assistant.json server.secret
VERDICT_FUNCTION_URL=      # https://w3gj444d.function2.insforge.app/verdict
                           # POSTed { session_id } when a transcript lands (Phase 3 fan-out)
