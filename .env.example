# Nebius Token Factory (LLM — panelist personas + deliberation)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1

# Vapi (voice)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=

# Insforge (backend / DB)
INSFORGE_API_KEY=
INSFORGE_PROJECT_URL=

# vapi-webhook (set these as Insforge function SECRETS, not local env):
#   npx @insforge/cli secrets set INSFORGE_API_KEY <key>
#   npx @insforge/cli secrets set INSFORGE_PROJECT_URL <url>
# Optional:
VAPI_SERVER_SECRET=        # shared secret; must match vapi/assistant.json server.secret
VERDICT_FUNCTION_URL=      # POSTed { session_id } when a transcript lands (Phase 3 fan-out)
