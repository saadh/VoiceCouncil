# Insforge frontend client. Copy to .env.local and fill in.
# Without these, the app runs in MOCK mode (clickable end-to-end, no backend).
# NOTE: confirm th7dp9ab's region — `npx @insforge/cli current` (assumed us-east).
VITE_INSFORGE_BASE_URL=https://th7dp9ab.us-east.insforge.app
VITE_INSFORGE_ANON_KEY=
# Edge-function host. REQUIRED: the SDK's functions.invoke() hits the wrong host
# (…functions.insforge.app -> 404/CORS); the real deployed host is …function2…
VITE_INSFORGE_FUNCTIONS_URL=https://th7dp9ab.function2.insforge.app

# Vapi (public/web key) — for the live web call in the interview phase.
VITE_VAPI_PUBLIC_KEY=
VITE_VAPI_ASSISTANT_ID=
